DATABASE_URL=postgresql+asyncpg://ledger_user:password@db:5432/ledger_db
REDIS_URL=redis://redis:6379
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=false

# Credentials locustfile.py uses to log in (on_start).
# Must be an existing user with role=ADMIN (create via POST /users as admin).
LOCUST_ADMIN_EMAIL=admin@example.com
LOCUST_ADMIN_PASSWORD=changeme

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
